<Configuration>
  <Target name="My Computer">
    <EnableDebuggingForAllVIs>0</EnableDebuggingForAllVIs>
    <VI name="Nordic nRF52 DK DTM Test.lvlib:Configure SA.vi">
      <Breakpoints>
        <NodeIndexes>
        </NodeIndexes>
        <SignalIndexes>
        </SignalIndexes>
      </Breakpoints>
      <Probes>
        <Generic>
          <SignalUID value="416"/>
        </Generic>
      </Probes>
    </VI>
    <VI name="Nordic nRF52 DK DTM Test.lvlib:DTM Receiver Test.vi">
      <Breakpoints>
        <NodeIndexes>
        </NodeIndexes>
        <SignalIndexes>
        </SignalIndexes>
      </Breakpoints>
      <Probes>
        <Generic>
          <SignalUID value="2952"/>
          <SignalUID value="1718"/>
          <SignalUID value="2108"/>
          <SignalUID value="1889"/>
          <SignalUID value="467"/>
          <SignalUID value="1093"/>
          <SignalUID value="2817"/>
          <SignalUID value="1713"/>
          <SignalUID value="1407"/>
        </Generic>
      </Probes>
    </VI>
    <VI name="Nordic nRF52 DK DTM Test.lvlib:DTM Transmitter Test.vi">
      <Breakpoints>
        <NodeIndexes>
        </NodeIndexes>
        <SignalIndexes>
        </SignalIndexes>
      </Breakpoints>
      <Probes>
        <Generic>
          <SignalUID value="414"/>
          <SignalUID value="1481"/>
          <SignalUID value="2512"/>
          <SignalUID value="2728"/>
        </Generic>
      </Probes>
    </VI>
    <VI name="Nordic nRF52 DK DTM Test.lvlib:Flash DTM Mode.vi">
