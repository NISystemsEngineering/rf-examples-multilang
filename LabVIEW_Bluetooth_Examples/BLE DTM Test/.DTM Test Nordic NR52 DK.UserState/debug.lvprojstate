        <SignalIndexes>
        </SignalIndexes>
      </Breakpoints>
      <Probes>
        <Generic>
          <SignalUID value="1921"/>
          <SignalUID value="599"/>
        </Generic>
      </Probes>
    </VI>
    <VI name="RFmxBT df1.vi">
