{
  // Starter debug configuration for this workspace.
  // Update the executable path(s) and optional debugger path as needed.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch WinForms (net48)",
      "type": "clr",
      "request": "launch",
      "program": "${workspaceFolder}/src/CSharpRfGenAndAnal.WinForms/bin/Release/net48/CSharpRfGenAndAnal.WinForms.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Launch Console (net48)",
      "type": "clr",
      "request": "launch",
      "program": "${workspaceFolder}/src/CSharpRfGenAndAnal.Console/bin/Release/net48/CSharpRfGenAndAnal.Console.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Attach to .NET Process",
      "type": "clr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    },
      "env": {
          "DOTNET_ENVIRONMENT": "Development"
      }
  }


      ],
  "compounds": [],
  // Optional: if your debugger extension supports a custom debugger runtime path,
  // add its setting here or in workspace/user settings.
  // "debuggerPath": "C:/path/to/your/debugger.exe"
}
